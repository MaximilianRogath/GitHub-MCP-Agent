# ============================================================
#  .env.example  —  Environment variable template
#  Copy to .env and fill in your values
#
#  Authentication: Azure resources use keyless auth
#  via AzureCliCredential. Run 'az login' before starting
#  the agent. No API keys required for Azure.
# ============================================================

# --- Microsoft Foundry (Agent Framework) --------------------
# Project endpoint from the Azure AI Foundry portal (Overview page)
AZURE_FOUNDRY_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project

# Model deployment name
AZURE_FOUNDRY_MODEL=gpt-4o

# --- GitHub MCP ---------------------------------------------
# GitHub Personal Access Token
# Create one at: https://github.com/settings/tokens
# Required scopes: repo, read:user
GITHUB_PAT=your-github-personal-access-token
